# state-service environment.
# Установить chmod 600 root:root.

# HTTP
STATE_SERVICE_HTTP_HOST=127.0.0.1
STATE_SERVICE_HTTP_PORT=8770

# Redis (localhost)
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TIMEOUT=5s

# Auth
# Сгенерировать через: openssl rand -hex 32
STATE_SERVICE_API_KEY=REPLACE_AT_DEPLOY

# Lock TTL по умолчанию (если клиент не передал свой)
STATE_SERVICE_DEFAULT_LOCK_TTL=300s

# Debug (false для production)
STATE_SERVICE_LOG_API_KEY_PREFIX=false
