# Шаблон Secret для compliance-logic
# В production заменяется на ESO/SealedSecrets или Vault Agent Injector
# Применять как: kubectl create -f secret.yaml.template (после подстановки base64 значений)
apiVersion: v1
kind: Secret
metadata:
  name: compliance-logic-secrets
  namespace: compliance-assistant
type: Opaque
data:
  # echo -n "PASSWORD" | base64
  POSTGRES_PASSWORD: PLACEHOLDER_BASE64_POSTGRES_PASSWORD
  API_KEY: PLACEHOLDER_BASE64_API_KEY
