[Unit]
Description=Attachment Service v1 (mail-stack)
After=network.target

[Service]
Type=simple
User=iakshin77
Group=iakshin77
UMask=0022
WorkingDirectory=/opt/mail-stack/attachment-service
EnvironmentFile=/etc/mail-stack/attachment-service.env
ExecStart=/opt/mail-stack/attachment-service/venv/bin/uvicorn server:app --host 127.0.0.1 --port 8766
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
