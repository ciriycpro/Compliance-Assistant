# summary-prep environment (DEC-0030)
# Расположение в production: /etc/mail-stack/summary-prep.env
# chmod 600 root:root

# === HTTP ===
SUMMARY_PREP_HTTP_HOST=127.0.0.1
SUMMARY_PREP_HTTP_PORT=8772

# === Auth ===
# Сгенерировать: openssl rand -hex 32
SUMMARY_PREP_API_KEY=REPLACE_AT_DEPLOY

# Логировать prefix невалидного X-API-Key (false для production)
SUMMARY_PREP_LOG_API_KEY_PREFIX=false

# === OpenRouter ===
OPENROUTER_API_KEY=REPLACE_AT_DEPLOY
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_SEC=60

# === Режим работы ===
# production | canary | mock
DISTILL_MODE=production
# Только для DISTILL_MODE=canary. Сгенерировать openssl rand -hex 16
DISTILL_CANARY_TOKEN=

# === Параметры дистилляции ===
DISTILL_MODEL=anthropic/claude-haiku-4.5

# Порог длины текста (chars) для запуска map-reduce
DISTILL_CHAR_THRESHOLD=80000

# Размер chunk'а (chars)
DISTILL_CHUNK_CHARS=50000

# Retry на каждый MAP/REDUCE call
DISTILL_MAX_RETRIES=2

# Если меньше N% chunks succeeded — fallback на метаданные
DISTILL_PARTIAL_REDUCE_THRESHOLD=0.5

# Версия промпта (включается в sha256 кэш-ключ; меняем при правках промптов)
DISTILL_PROMPT_VERSION=v1

# === Кэш ===
DISTILL_CACHE_DIR=/var/lib/summary-prep/cache
DISTILL_CACHE_TTL_DAYS=30
